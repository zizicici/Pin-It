    "settings.cloudKitSync.alert.accountChanged.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم إيقاف مزامنة CloudKit لأن حساب iCloud على هذا الجهاز قد تغيّر. أعِد تفعيلها في الإعدادات لبدء المزامنة مع الحساب الجديد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung wurde deaktiviert, weil sich der iCloud-Account auf diesem Gerät geändert hat. Aktiviere sie in den Einstellungen erneut, um die Synchronisierung mit dem neuen Account zu starten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync was turned off because the iCloud account on this device changed. Re-enable it in Settings to start syncing with the new account."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se desactivó porque la cuenta de iCloud de este dispositivo cambió. Vuelve a activarla en Ajustes para empezar a sincronizar con la nueva cuenta."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se desactivó porque la cuenta de iCloud de este dispositivo cambió. Vuelve a activarla en Configuración para empezar a sincronizar con la nueva cuenta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit a été désactivée car le compte iCloud de cet appareil a changé. Réactivez-la dans Réglages pour commencer à synchroniser avec le nouveau compte."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit è stata disattivata perché l'account iCloud su questo dispositivo è cambiato. Riattivala in Impostazioni per iniziare a sincronizzare con il nuovo account."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデバイスの iCloud アカウントが変更されたため、CloudKit 同期がオフになりました。新しいアカウントで同期するには、設定で再度オンにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기의 iCloud 계정이 변경되어 CloudKit 동기화가 꺼졌습니다. 새 계정으로 동기화하려면 설정에서 다시 켜십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Sincronização do CloudKit foi desativada porque a conta do iCloud neste dispositivo foi alterada. Reative-a nos Ajustes para começar a sincronizar com a nova conta."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização CloudKit foi desativada porque a conta iCloud neste dispositivo foi alterada. Reative-a nas Definições para começar a sincronizar com a nova conta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация через CloudKit была отключена, так как учётная запись iCloud на этом устройстве изменилась. Включите её снова в Настройках, чтобы начать синхронизацию с новой учётной записью."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit вимкнено, оскільки обліковий запис iCloud на цьому пристрої змінився. Увімкніть її знову в Параметрах, щоб почати синхронізацію з новим обліковим записом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由于这台设备的 iCloud 账号发生了变化,CloudKit 同步已自动关闭。在设置中重新启用即可使用新账号同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由於這台裝置的 iCloud 帳號發生了變化,CloudKit 同步已自動關閉。在設定中重新啓用即可使用新帳號同步。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由於這部裝置的 iCloud 帳號發生了變化,CloudKit 同步已自動關閉。在設定中重新啓用即可使用新帳號同步。"
          }
        }
      }
    },
