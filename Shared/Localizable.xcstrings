        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn weiterhin Synchronisierungsfehler auftreten, erstelle die CloudKit-Synchronisierung von diesem Gerät neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If sync errors keep returning, rebuild CloudKit sync from this device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si los errores de sincronización siguen apareciendo, reconstruye la sincronización con CloudKit desde este dispositivo."
          }
        },
        "es-419" : {
          "stringUnit" : {
