    "settings.cloudKitSync.pendingReset.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هناك إعادة بناء معلّقة لـ CloudKit وستُعاد المحاولة عند توفّر iCloud. للتخلي عنها، أوقِف مزامنة CloudKit، ثم استخدم مسح بيانات CloudKit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine CloudKit-Neuerstellung steht aus und wird erneut versucht, sobald iCloud verfügbar ist. Um sie abzubrechen, deaktiviere die CloudKit-Synchronisierung und verwende dann „CloudKit-Daten löschen“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A CloudKit rebuild is pending and will retry when iCloud is available. To abandon it, turn off CloudKit Sync, then use Clear CloudKit Data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hay una reconstrucción de CloudKit pendiente que se reintentará cuando iCloud esté disponible. Para cancelarla, desactiva la sincronización con CloudKit y luego usa Borrar datos de CloudKit."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hay una reconstrucción de CloudKit pendiente que se reintentará cuando iCloud esté disponible. Para descartarla, desactiva la sincronización con CloudKit y luego usa Borrar datos de CloudKit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une reconstruction CloudKit est en attente et réessaiera lorsque iCloud sera disponible. Pour l’abandonner, désactivez la synchronisation CloudKit, puis utilisez Effacer les données CloudKit."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È in attesa una ricostruzione CloudKit, che riproverà quando iCloud sarà disponibile. Per annullarla, disattiva la sincronizzazione CloudKit, poi usa Cancella i dati CloudKit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit の再構築が保留中で、iCloud が利用可能になったときに再試行されます。中止するには、CloudKit 同期をオフにしてから「CloudKit データを消去」を使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 재구축이 대기 중이며 iCloud를 사용할 수 있을 때 다시 시도합니다. 중단하려면 CloudKit 동기화를 끈 다음 CloudKit 데이터 지우기를 사용하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma reconstrução do CloudKit está pendente e será repetida quando o iCloud estiver disponível. Para abandoná-la, desative a Sincronização do CloudKit e use Apagar Dados do CloudKit."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Está pendente uma reconstrução do CloudKit, que será repetida quando o iCloud estiver disponível. Para a abandonar, desative a sincronização CloudKit e depois use Limpar dados do CloudKit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перестроение CloudKit ожидает выполнения и будет повторено, когда iCloud станет доступен. Чтобы отказаться от него, отключите синхронизацию через CloudKit, а затем используйте «Очистить данные CloudKit»."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перебудову CloudKit очікується, і спробу буде повторено, коли iCloud стане доступним. Щоб відмовитися від неї, вимкніть синхронізацію CloudKit, а потім скористайтеся «Очистити дані CloudKit»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 重建尚未完成，将在 iCloud 可用时重试。如要放弃重建，请先关闭 CloudKit 同步，再使用「清空 CloudKit 数据」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 重建尚未完成，將在 iCloud 可用時重試。如要放棄重建，請先關閉 CloudKit 同步，再使用「清空 CloudKit 資料」。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 重建尚未完成，將在 iCloud 可用時重試。如要放棄重建，請先關閉 CloudKit 同步，再使用「清空 CloudKit 資料」。"
          }
        }
      }
    },
