          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цей приклад запису відображатиметься на екрані блокування та в активностях у реальному часі в Dynamic Island."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
