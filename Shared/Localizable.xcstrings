    "settings.cloudKitSync.rebuild.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "This deletes Pin It's CloudKit sync database and uploads the records currently on this device again. This device becomes the source of truth; records that exist only on other devices can be removed when those devices sync."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "This deletes Pin It's CloudKit sync database and uploads the records currently on this device again. This device becomes the source of truth; records that exist only on other devices can be removed when those devices sync."
          }
