    "settings.reset.alert.cloudKit.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مزامنة CloudKit مُفعّلة. تؤدي إعادة تعيين البيانات إلى مسح السجلّات المحلية الآن، وإلى مسح سجلّات %@ من CloudKit عند توفّر iCloud. وستتم مزامنة هذا الحذف مع أجهزتك الأخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung ist aktiviert. Beim Zurücksetzen der Daten werden die lokalen Datensätze sofort gelöscht und die Datensätze von %@ aus CloudKit gelöscht, sobald iCloud verfügbar ist. Diese Löschung wird mit deinen anderen Geräten synchronisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync is enabled. Resetting data clears local records now and clears %@ records from CloudKit when iCloud is available. That deletion will sync to your other devices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización de CloudKit está activada. Al restablecer los datos se borran ahora los registros locales y se borran los registros de %@ de CloudKit cuando iCloud esté disponible. Esa eliminación se sincronizará con tus otros dispositivos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización de CloudKit está activada. Al restablecer los datos se borran ahora los registros locales y se borran los registros de %@ de CloudKit cuando iCloud esté disponible. Esa eliminación se sincronizará con tus otros dispositivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit est activée. La réinitialisation des données efface les enregistrements locaux maintenant et efface les enregistrements de %@ dans CloudKit lorsque iCloud est disponible. Cette suppression sera synchronisée avec vos autres appareils."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit è attiva. Il ripristino dei dati cancella subito i record locali e cancella i record di %@ da CloudKit quando iCloud è disponibile. Tale eliminazione verrà sincronizzata con gli altri tuoi dispositivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同期がオンになっています。データをリセットすると、ローカルのレコードがすぐに消去され、iCloud が利用可能になったときに CloudKit 上の %@ のレコードも消去されます。その削除は他のデバイスにも同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 동기화가 켜져 있습니다. 데이터를 재설정하면 로컬 기록이 즉시 지워지고, iCloud를 사용할 수 있을 때 CloudKit의 %@ 기록도 지워집니다. 이 삭제는 다른 기기에도 동기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do CloudKit está ativada. Redefinir os dados limpa os registros locais agora e limpa os registros do %@ no CloudKit quando o iCloud estiver disponível. Essa exclusão será sincronizada com seus outros dispositivos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do CloudKit está ativada. Repor os dados limpa os registos locais agora e limpa os registos do %@ no CloudKit quando o iCloud estiver disponível. Essa eliminação será sincronizada com os seus outros dispositivos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация CloudKit включена. Сброс данных удаляет локальные записи сейчас и удаляет записи %@ из CloudKit, когда iCloud станет доступен. Это удаление синхронизируется с другими вашими устройствами."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit увімкнено. Скидання даних видаляє локальні записи зараз і видаляє записи %@ з CloudKit, коли iCloud стане доступним. Це видалення синхронізується з іншими вашими пристроями."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已开启。重置数据会立即清空本地记录，并在 iCloud 可用时清空 CloudKit 中的「%@」记录；该删除会同步到你的其他设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已開啓。重置資料會立即清空本機記錄，並在 iCloud 可用時清空 CloudKit 中的「%@」記錄；該刪除會同步到你的其他裝置。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已開啓。重置資料會立即清空本機記錄，並在 iCloud 可用時清空 CloudKit 中的「%@」記錄；該刪除會同步到你的其他裝置。"
          }
        }
      }
    },
    "settings.reset.alert.cloudKitDisabled.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مزامنة CloudKit مُعطّلة حاليًا، لكن هذا الجهاز استخدم CloudKit من قبل. تؤدي إعادة تعيين البيانات إلى مسح السجلّات المحلية فقط؛ استخدم «مسح بيانات CloudKit» لحذف سجلّات %@ من CloudKit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung ist derzeit deaktiviert, aber dieses Gerät hat CloudKit bereits verwendet. Beim Zurücksetzen der Daten werden nur die lokalen Datensätze gelöscht; verwende „CloudKit-Daten löschen“, um die Datensätze von %@ aus CloudKit zu löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync is currently off, but this device has used CloudKit before. Resetting data clears local records only; use Clear CloudKit Data to delete %@ records from CloudKit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización de CloudKit está desactivada actualmente, pero este dispositivo ha usado CloudKit antes. Al restablecer los datos solo se borran los registros locales; usa Borrar datos de CloudKit para eliminar los registros de %@ de CloudKit."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización de CloudKit está desactivada actualmente, pero este dispositivo ya ha usado CloudKit. Al restablecer los datos solo se borran los registros locales; usa Borrar datos de CloudKit para eliminar los registros de %@ de CloudKit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit est actuellement désactivée, mais cet appareil a déjà utilisé CloudKit. La réinitialisation des données n’efface que les enregistrements locaux ; utilisez Effacer les données CloudKit pour supprimer les enregistrements de %@ dans CloudKit."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit è attualmente disattivata, ma questo dispositivo ha già usato CloudKit. Il ripristino dei dati cancella solo i record locali; usa Cancella dati CloudKit per eliminare i record di %@ da CloudKit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同期は現在オフですが、このデバイスは以前 CloudKit を使用したことがあります。データをリセットしてもローカルのレコードのみが消去されます。CloudKit 上の %@ のレコードを削除するには「CloudKit データを消去」を使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 동기화가 현재 꺼져 있지만, 이 기기는 이전에 CloudKit을 사용한 적이 있습니다. 데이터를 재설정하면 로컬 기록만 지워집니다. CloudKit의 %@ 기록을 삭제하려면 CloudKit 데이터 지우기를 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do CloudKit está desativada no momento, mas este dispositivo já usou o CloudKit. Redefinir os dados limpa apenas os registros locais; use Limpar Dados do CloudKit para excluir os registros do %@ no CloudKit."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do CloudKit está atualmente desativada, mas este dispositivo já usou o CloudKit. Repor os dados limpa apenas os registos locais; use Limpar Dados do CloudKit para eliminar os registos do %@ no CloudKit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация CloudKit сейчас выключена, но это устройство ранее использовало CloudKit. Сброс данных удаляет только локальные записи; используйте «Очистить данные CloudKit», чтобы удалить записи %@ из CloudKit."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit зараз вимкнено, але цей пристрій раніше використовував CloudKit. Скидання даних видаляє лише локальні записи; скористайтеся «Очистити дані CloudKit», щоб видалити записи %@ з CloudKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已关闭，但这台设备之前使用过 CloudKit。重置数据只会清空本地记录；如需删除 CloudKit 中的「%@」记录，请使用清空 CloudKit 数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已關閉，但這台裝置之前使用過 CloudKit。重置資料只會清空本機記錄；如需刪除 CloudKit 中的「%@」記錄，請使用清空 CloudKit 資料。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已關閉，但這部裝置之前使用過 CloudKit。重置資料只會清空本機記錄；如需刪除 CloudKit 中的「%@」記錄，請使用清空 CloudKit 資料。"
          }
        }
      }
    },
