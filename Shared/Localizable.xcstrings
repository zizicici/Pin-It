    "settings.cloudKitSync.clear.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي ذلك إلى حذف سجلات %@ من CloudKit دون تغيير السجلات المحلية على هذا الجهاز. ستتم مزامنة الحذف مع الأجهزة الأخرى التي تستخدم مزامنة CloudKit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden %@ Datensätze aus CloudKit gelöscht, ohne die lokalen Datensätze auf diesem Gerät zu ändern. Die Löschung wird mit anderen Geräten synchronisiert, die die CloudKit-Synchronisierung verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This deletes %@ records from CloudKit without changing local records on this device. The deletion will sync to other devices that use CloudKit Sync."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina %@ registros de CloudKit sin modificar los registros locales de este dispositivo. La eliminación se sincronizará con los demás dispositivos que usen la sincronización con CloudKit."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina %@ registros de CloudKit sin cambiar los registros locales de este dispositivo. La eliminación se sincronizará con los demás dispositivos que usen la sincronización con CloudKit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprime %@ enregistrements de CloudKit sans modifier les enregistrements locaux de cet appareil. La suppression sera synchronisée vers les autres appareils qui utilisent la synchronisation CloudKit."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione elimina %@ record da CloudKit senza modificare i record locali su questo dispositivo. L'eliminazione verrà sincronizzata con gli altri dispositivi che usano la sincronizzazione CloudKit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、このデバイス上のローカルレコードを変更せずに、CloudKit から %@ 件のレコードを削除します。この削除は、CloudKit 同期を使用している他のデバイスにも同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업은 이 기기의 로컬 레코드는 변경하지 않고 CloudKit에서 %@개의 레코드를 삭제합니다. 삭제는 CloudKit 동기화를 사용하는 다른 기기에도 동기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto apaga %@ registros do CloudKit sem alterar os registros locais deste dispositivo. A exclusão será sincronizada com outros dispositivos que usam a Sincronização do CloudKit."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto elimina %@ registos do CloudKit sem alterar os registos locais neste dispositivo. A eliminação será sincronizada para os outros dispositivos que usam a sincronização CloudKit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это удалит записи (%@) из CloudKit, не изменяя локальные записи на этом устройстве. Удаление синхронизируется с другими устройствами, использующими синхронизацию через CloudKit."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це видалить записи «%@» з CloudKit, не змінюючи локальні записи на цьому пристрої. Видалення синхронізується з іншими пристроями, що використовують синхронізацію CloudKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会删除 CloudKit 中的「%@」记录，但不会改变这台设备上的本地记录。该删除会同步到其他使用 CloudKit 同步的设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會刪除 CloudKit 中的「%@」記錄，但不會改變這台裝置上的本機記錄。該刪除會同步到其他使用 CloudKit 同步的裝置。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會刪除 CloudKit 中的「%@」記錄，但不會改變這部裝置上的本機記錄。該刪除會同步到其他使用 CloudKit 同步的裝置。"
          }
        }
      }
    },
