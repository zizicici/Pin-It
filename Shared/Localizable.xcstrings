    "thanks.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيحذف هذا اللافتة إلى الأبد، لا يمكن التراجع عن هذا الإجراء"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies wird das Banner endgültig löschen. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will delete the banner forever. You cannot undo this action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará el banner para siempre. No podrás deshacer esta acción."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará el banner para siempre. No podrás deshacer esta acción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement la bannière. Vous ne pourrez pas annuler cette action."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo eliminerà il banner per sempre. Non potrai annullare questa azione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このバナーを完全に削除します。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 배너가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso excluirá o banner para sempre. Você não pode desfazer esta ação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto irá eliminar o banner para sempre. Não pode anular esta ação."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это навсегда удалит баннер. Вы не сможете отменить это действие."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це назавди видалить банер. Ви не зможете скасувати цю дію."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你将永久性地删除感谢栏，这个操作不能回退。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
