    "settings.reset.alert.cloudKit.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync is enabled. Resetting data clears local records now and clears Pin It records from CloudKit when iCloud is available. That deletion will sync to your other devices."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已开启。重置数据会立即清空本地记录，并在 iCloud 可用时清空 CloudKit 中的 Pin It 记录；该删除会同步到你的其他设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已開啓。重置資料會立即清空本機記錄，並在 iCloud 可用時清空 CloudKit 中的 Pin It 記錄；該刪除會同步到你的其他裝置。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已開啓。重置資料會立即清空本機記錄，並在 iCloud 可用時清空 CloudKit 中的 Pin It 記錄；該刪除會同步到你的其他裝置。"
          }
        }
      }
    },
    "settings.reset.alert.cloudKitDisabled.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync is currently off, but this device has used CloudKit before. Resetting data clears local records only; use Clear CloudKit Data to delete Pin It records from CloudKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已关闭，但这台设备之前使用过 CloudKit。重置数据只会清空本地记录；如需删除 CloudKit 中的 Pin It 记录，请使用清空 CloudKit 数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已關閉，但這台裝置之前使用過 CloudKit。重置資料只會清空本機記錄；如需刪除 CloudKit 中的 Pin It 記錄，請使用清空 CloudKit 資料。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步目前已關閉，但這部裝置之前使用過 CloudKit。重置資料只會清空本機記錄；如需刪除 CloudKit 中的 Pin It 記錄，請使用清空 CloudKit 資料。"
          }
        }
      }
    },
