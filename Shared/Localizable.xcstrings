    "settings.cloudKitSync.enable.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتحقق %@ من حساب iCloud الخاص بك ثم يزامن المنشورات والأنماط عبر قاعدة بيانات CloudKit الخاصة بك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ prüft deinen iCloud-Account und synchronisiert dann Posts und Stile über deine private CloudKit-Datenbank."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ will check your iCloud account and then sync posts and styles through your private CloudKit database."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ comprobará tu cuenta de iCloud y luego sincronizará las publicaciones y los estilos a través de tu base de datos privada de CloudKit."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ comprobará tu cuenta de iCloud y luego sincronizará las publicaciones y los estilos a través de tu base de datos privada de CloudKit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ va vérifier votre compte iCloud, puis synchroniser les publications et les styles via votre base de données CloudKit privée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ verificherà il tuo account iCloud e poi sincronizzerà post e stili tramite il tuo database CloudKit privato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は iCloud アカウントを確認したあと、プライベート CloudKit データベースを通じて投稿とスタイルを同期します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@이(가) iCloud 계정을 확인한 다음 개인 CloudKit 데이터베이스를 통해 게시물과 스타일을 동기화합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ verificará sua conta do iCloud e, em seguida, sincronizará notas e estilos através do seu banco de dados privado do CloudKit."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ irá verificar a sua conta iCloud e depois sincronizar as publicações e os estilos através da sua base de dados privada do CloudKit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ проверит вашу учётную запись iCloud, а затем синхронизирует заметки и стили через вашу частную базу данных CloudKit."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ перевірить ваш обліковий запис iCloud, а потім синхронізує дописи та стилі через вашу приватну базу даних CloudKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」会先检查你的 iCloud 账号，然后通过你的私人 CloudKit 数据库同步便签和样式。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」會先檢查你的 iCloud 帳號，然後透過你的私人 CloudKit 資料庫同步便籤和樣式。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」會先檢查你的 iCloud 帳戶，然後透過你的私人 CloudKit 資料庫同步便籤和樣式。"
          }
        }
      }
    },
