    "settings.cloudKitSync.clearDiagnostics.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي ذلك إلى حذف أحداث المزامنة المسجّلة محليًا. لن يتأثر منشوراتك ولا بيانات CloudKit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden die lokal aufgezeichneten Synchronisierungsereignisse gelöscht. Deine Posts und CloudKit-Daten sind nicht betroffen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This deletes the locally recorded sync events. Your posts and CloudKit data are not affected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina los eventos de sincronización registrados localmente. Tus publicaciones y tus datos de CloudKit no se ven afectados."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina los eventos de sincronización registrados localmente. Tus publicaciones y los datos de CloudKit no se ven afectados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprime les événements de synchronisation enregistrés localement. Vos publications et vos données CloudKit ne sont pas affectées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione elimina gli eventi di sincronizzazione registrati localmente. I tuoi post e i dati CloudKit non vengono interessati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、ローカルに記録された同期イベントが削除されます。投稿や CloudKit データには影響しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업은 로컬에 기록된 동기화 이벤트를 삭제합니다. 게시물과 CloudKit 데이터에는 영향을 주지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto apaga os eventos de sincronização registrados localmente. Suas notas e os dados do CloudKit não são afetados."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto elimina os eventos de sincronização registados localmente. As suas publicações e os dados do CloudKit não são afetados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это удалит локально записанные события синхронизации. Ваши заметки и данные CloudKit не затрагиваются."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це видалить локально записані події синхронізації. Ваші дописи та дані CloudKit не зачіпаються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将删除本地记录的同步事件，不会影响你的内容和 CloudKit 数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將刪除本機記錄的同步事件，不會影響你的內容和 CloudKit 資料。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將刪除本機記錄的同步事件，不會影響你的內容和 CloudKit 資料。"
