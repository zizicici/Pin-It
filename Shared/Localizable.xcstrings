    "settings.cloudKitSync.diagnostics.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يسجّل أحداث المزامنة الأخيرة (البيانات الوصفية فقط، دون محتوى المنشورات) لتتمكّن من تصديرها عند الإبلاغ عن مشكلة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeichnet die letzten Synchronisierungsereignisse auf (nur Metadaten, kein Post-Inhalt), damit du sie beim Melden eines Problems exportieren kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Records recent sync events (metadata only, no post content) so you can export them when reporting a problem."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra los eventos de sincronización recientes (solo metadatos, sin el contenido de las publicaciones) para que puedas exportarlos al informar de un problema."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra los eventos de sincronización recientes (solo metadatos, sin el contenido de las publicaciones) para que puedas exportarlos al reportar un problema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistre les événements de synchronisation récents (métadonnées uniquement, sans le contenu des publications) afin que vous puissiez les exporter lors du signalement d’un problème."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra i recenti eventi di sincronizzazione (solo metadati, nessun contenuto dei post) così puoi esportarli quando segnali un problema."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最近の同期イベント（メタデータのみ、投稿の内容は含みません）を記録し、問題を報告する際に書き出せるようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최근 동기화 이벤트를 기록하여(메타데이터만 포함, 게시물 내용은 미포함) 문제를 신고할 때 내보낼 수 있도록 합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra eventos recentes de sincronização (apenas metadados, sem o conteúdo das notas) para que você possa exportá-los ao relatar um problema."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regista os eventos de sincronização recentes (apenas metadados, sem o conteúdo das publicações) para que os possa exportar ao comunicar um problema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записывает недавние события синхронизации (только метаданные, без содержимого заметок), чтобы вы могли экспортировать их при сообщении о проблеме."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записує останні події синхронізації (лише метадані, без вмісту допису), щоб ви могли експортувати їх під час повідомлення про проблему."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "记录最近的同步事件（仅元数据，不含内容），便于你在反馈问题时导出。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記錄最近的同步事件（僅中繼資料，不含內容），方便你在回報問題時匯出。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記錄最近的同步事件（僅中繼資料，不含內容），方便你在回報問題時匯出。"
          }
        }
      }
