          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se os erros de sincronização continuarem a surgir, reconstrua a sincronização CloudKit a partir deste dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если ошибки синхронизации продолжают появляться, перестройте синхронизацию через CloudKit с этого устройства."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо помилки синхронізації постійно повертаються, перебудуйте синхронізацію CloudKit із цього пристрою."
          }
