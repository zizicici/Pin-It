    "settings.cloudKitSync.clear.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي المسح إلى إزالة سجلات CloudKit الخاصة بك ومزامنة الحذف مع الأجهزة الأخرى؛ مع الاحتفاظ بالسجلات على هذا الجهاز. متاح فقط أثناء إيقاف المزامنة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Löschen werden deine CloudKit-Datensätze entfernt und die Löschung wird mit anderen Geräten synchronisiert; die Datensätze auf diesem Gerät bleiben erhalten. Nur verfügbar, wenn die Synchronisierung deaktiviert ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear removes your CloudKit records and syncs the deletion to other devices; records on this device are kept. Available only while sync is off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borrar elimina tus registros de CloudKit y sincroniza la eliminación con los demás dispositivos; los registros de este dispositivo se conservan. Solo está disponible cuando la sincronización está desactivada."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borrar elimina tus registros de CloudKit y sincroniza la eliminación con los demás dispositivos; los registros de este dispositivo se conservan. Solo está disponible cuando la sincronización está desactivada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacer supprime vos enregistrements CloudKit et synchronise la suppression vers les autres appareils ; les enregistrements de cet appareil sont conservés. Disponible uniquement lorsque la synchronisation est désactivée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cancellazione rimuove i tuoi record CloudKit e sincronizza l'eliminazione con gli altri dispositivi; i record su questo dispositivo vengono mantenuti. Disponibile solo quando la sincronizzazione è disattivata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "消去すると、CloudKit のレコードが削除され、その削除が他のデバイスにも同期されます。このデバイス上のレコードは保持されます。同期がオフのときのみ使用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지우기는 CloudKit 레코드를 제거하고 삭제를 다른 기기에 동기화합니다. 이 기기의 레코드는 유지됩니다. 동기화가 꺼져 있을 때만 사용할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apagar remove seus registros do CloudKit e sincroniza a exclusão com outros dispositivos; os registros deste dispositivo são mantidos. Disponível apenas quando a sincronização está desativada."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpar remove os seus registos do CloudKit e sincroniza a eliminação para os outros dispositivos; os registos neste dispositivo são mantidos. Disponível apenas quando a sincronização está desativada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очистка удаляет ваши записи CloudKit и синхронизирует удаление с другими устройствами; записи на этом устройстве сохраняются. Доступно только при отключённой синхронизации."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очищення видаляє ваші записи CloudKit і синхронізує видалення з іншими пристроями; записи на цьому пристрої зберігаються. Доступно лише коли синхронізацію вимкнено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清空会移除 CloudKit 上的记录并把删除同步到其他设备，本机记录会保留。仅在关闭同步后可用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清空會移除 CloudKit 上的記錄並把刪除同步到其他裝置，本機記錄會保留。僅在關閉同步後可用。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清空會移除 CloudKit 上的記錄並把刪除同步到其他裝置，本機記錄會保留。僅在關閉同步後可用。"
          }
        }
      }
    },
