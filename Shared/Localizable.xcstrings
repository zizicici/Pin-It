    "settings.cloudKitSync.rebuild.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي ذلك إلى حذف قاعدة بيانات مزامنة CloudKit الخاصة بـ %@ وإعادة رفع السجلات الموجودة حاليًا على هذا الجهاز. يصبح هذا الجهاز هو المصدر الموثوق؛ ويمكن إزالة السجلات الموجودة على الأجهزة الأخرى فقط عند مزامنة تلك الأجهزة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch wird die CloudKit-Synchronisierungsdatenbank von %@ gelöscht und die derzeit auf diesem Gerät vorhandenen Datensätze werden erneut hochgeladen. Dieses Gerät wird zur maßgeblichen Quelle; Datensätze, die nur auf anderen Geräten vorhanden sind, können entfernt werden, wenn diese Geräte synchronisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This deletes %@'s CloudKit sync database and uploads the records currently on this device again. This device becomes the source of truth; records that exist only on other devices can be removed when those devices sync."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina la base de datos de sincronización de CloudKit de %@ y vuelve a subir los registros que hay actualmente en este dispositivo. Este dispositivo se convierte en la fuente de referencia; los registros que solo existen en otros dispositivos pueden eliminarse cuando esos dispositivos se sincronicen."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina la base de datos de sincronización de CloudKit de %@ y vuelve a subir los registros que están actualmente en este dispositivo. Este dispositivo se convierte en la fuente principal; los registros que solo existen en otros dispositivos se pueden eliminar cuando esos dispositivos se sincronicen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprime la base de données de synchronisation CloudKit de %@ et téléverse à nouveau les enregistrements actuellement présents sur cet appareil. Cet appareil devient la référence ; les enregistrements qui n’existent que sur d’autres appareils peuvent être supprimés lorsque ces appareils se synchronisent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione elimina il database di sincronizzazione CloudKit di %@ e carica di nuovo i record attualmente presenti su questo dispositivo. Questo dispositivo diventa la fonte di riferimento; i record che esistono solo su altri dispositivi possono essere rimossi quando quei dispositivi si sincronizzano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、%@ の CloudKit 同期データベースを削除し、現在このデバイスにあるレコードを再度アップロードします。このデバイスが信頼できる情報源になります。他のデバイスにのみ存在するレコードは、それらのデバイスが同期したときに削除されることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업은 %@의 CloudKit 동기화 데이터베이스를 삭제하고 현재 이 기기에 있는 레코드를 다시 업로드합니다. 이 기기가 기준이 되며, 다른 기기에만 존재하는 레코드는 해당 기기가 동기화될 때 제거될 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto apaga o banco de dados de sincronização do CloudKit do %@ e envia novamente os registros que estão atualmente neste dispositivo. Este dispositivo se torna a fonte de referência; os registros que existem apenas em outros dispositivos podem ser removidos quando esses dispositivos sincronizarem."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto elimina a base de dados de sincronização do CloudKit do %@ e volta a carregar os registos que se encontram atualmente neste dispositivo. Este dispositivo torna-se a fonte de verdade; os registos que existem apenas noutros dispositivos podem ser removidos quando esses dispositivos sincronizarem."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это удалит базу данных синхронизации CloudKit приложения %@ и снова загрузит записи, которые сейчас находятся на этом устройстве. Это устройство станет источником истины; записи, существующие только на других устройствах, могут быть удалены при синхронизации этих устройств."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це видаляє базу даних синхронізації CloudKit програми «%@» та знову вивантажує записи, що зараз є на цьому пристрої. Цей пристрій стає джерелом істини; записи, що існують лише на інших пристроях, може бути видалено, коли ті пристрої синхронізуються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会删除「%@」的 CloudKit 同步数据库，并重新上传这台设备上的当前记录。这台设备会成为同步来源；只存在于其他设备上的记录，可能会在那些设备同步时被移除。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會刪除「%@」的 CloudKit 同步資料庫，並重新上傳這台裝置上的目前記錄。這台裝置會成為同步來源；只存在於其他裝置上的記錄，可能會在那些裝置同步時被移除。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會刪除「%@」的 CloudKit 同步資料庫，並重新上傳這部裝置上的目前記錄。這部裝置會成為同步來源；只存在於其他裝置上的記錄，可能會在那些裝置同步時被移除。"
          }
        }
      }
    },
