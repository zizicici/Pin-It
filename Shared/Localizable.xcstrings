    "intent.post.get.all.description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الحصول على جميع المنشورات المثبتة، قد يتطلب وقتاً طويلاً"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
