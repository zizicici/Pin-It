    "settings.cloudKitSync.rebuild.partial.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمت إعادة بناء مزامنة CloudKit، لكن تعذّر رفع بعض السجلات. سيعيد %@ المحاولة تلقائيًا؛ وتظهر التفاصيل أسفل صف مزامنة CloudKit في الإعدادات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung wurde neu erstellt, aber einige Datensätze konnten nicht hochgeladen werden. %@ versucht es automatisch erneut; die Details werden in den Einstellungen unter der Zeile „CloudKit-Synchronisierung“ angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit sync was rebuilt, but some records could not be uploaded. %@ will retry automatically; details are shown under the CloudKit Sync row in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se reconstruyó, pero algunos registros no se pudieron subir. %@ lo intentará de nuevo automáticamente; los detalles se muestran bajo la fila Sincronización con CloudKit en Ajustes."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se reconstruyó, pero algunos registros no se pudieron subir. %@ lo intentará de nuevo automáticamente; los detalles se muestran debajo de la fila Sincronización con CloudKit en Configuración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit a été reconstruite, mais certains enregistrements n’ont pas pu être téléversés. %@ réessaiera automatiquement ; les détails sont affichés sous la ligne Synchronisation CloudKit dans Réglages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit è stata ricostruita, ma alcuni record non sono stati caricati. %@ riproverà automaticamente; i dettagli sono mostrati sotto la voce Sincronizzazione CloudKit in Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同期を再構築しましたが、一部のレコードをアップロードできませんでした。%@ が自動的に再試行します。詳細は設定の CloudKit 同期の行の下に表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 동기화를 재구축했지만 일부 레코드를 업로드할 수 없습니다. %@이(가) 자동으로 다시 시도합니다. 자세한 내용은 설정의 CloudKit 동기화 행 아래에 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização do CloudKit foi reconstruída, mas não foi possível enviar alguns registros. O %@ tentará novamente automaticamente; os detalhes são exibidos abaixo da linha Sincronização do CloudKit nos Ajustes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização CloudKit foi reconstruída, mas não foi possível carregar alguns registos. O %@ irá tentar novamente de forma automática; os detalhes são apresentados sob a linha Sincronização CloudKit nas Definições."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация через CloudKit была перестроена, но некоторые записи не удалось загрузить. %@ повторит попытку автоматически; подробности показаны под строкой «Синхронизация через CloudKit» в Настройках."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit перебудовано, але деякі записи не вдалося вивантажити. %@ повторить спробу автоматично; подробиці показано під рядком «Синхронізація CloudKit» у Параметрах."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已重建，但部分记录未能上传。「%@」会自动重试；详情会显示在设置页的 CloudKit 同步行下方。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步已重建，但部分記錄未能上傳。「%@」會自動重試；詳情會顯示在設定頁的 CloudKit 同步列下方。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
