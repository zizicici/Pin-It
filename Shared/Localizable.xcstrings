    "settings.cloudKitSync.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مزامنة CloudKit متوقفة افتراضيًا. عند تفعيلها، يزامن %@ المنشورات والأنماط عبر قاعدة بيانات CloudKit الخاصة بك؛ وتتم مزامنة التغييرات التي تُجرى أثناء إيقافها (بما في ذلك عمليات الحذف) في المرة التالية التي يُعاد فيها تفعيلها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung ist standardmäßig deaktiviert. Wenn sie aktiviert ist, synchronisiert %@ Posts und Stile über deine private CloudKit-Datenbank; Änderungen, die vorgenommen werden, während sie deaktiviert ist (einschließlich Löschungen), werden synchronisiert, sobald sie das nächste Mal wieder aktiviert wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync is off by default. When enabled, %@ syncs posts and styles through your private CloudKit database; changes made while it is off (including deletions) sync the next time it is turned back on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit está desactivada por omisión. Cuando se activa, %@ sincroniza las publicaciones y los estilos a través de tu base de datos privada de CloudKit; los cambios realizados mientras está desactivada (incluidas las eliminaciones) se sincronizan la próxima vez que se vuelve a activar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit está desactivada de forma predeterminada. Cuando se activa, %@ sincroniza las publicaciones y los estilos a través de tu base de datos privada de CloudKit; los cambios hechos mientras está desactivada (incluidas las eliminaciones) se sincronizan la próxima vez que se vuelve a activar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit est désactivée par défaut. Une fois activée, %@ synchronise les publications et les styles via votre base de données CloudKit privée ; les modifications effectuées lorsqu’elle est désactivée (y compris les suppressions) sont synchronisées à sa prochaine réactivation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit è disattivata per impostazione predefinita. Quando è attiva, %@ sincronizza post e stili tramite il tuo database CloudKit privato; le modifiche apportate mentre è disattivata (incluse le eliminazioni) vengono sincronizzate la volta successiva che la riattivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同期はデフォルトでオフになっています。オンにすると、%@ はプライベート CloudKit データベースを通じて投稿とスタイルを同期します。オフの間に行った変更（削除を含む）は、次にオンにしたときに同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 동기화는 기본적으로 꺼져 있습니다. 켜면 %@이(가) 개인 CloudKit 데이터베이스를 통해 게시물과 스타일을 동기화합니다. 꺼져 있는 동안 변경한 사항(삭제 포함)은 다시 켤 때 동기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Sincronização do CloudKit está desativada por padrão. Quando ativada, o %@ sincroniza notas e estilos através do seu banco de dados privado do CloudKit; as alterações feitas enquanto ela está desativada (incluindo exclusões) são sincronizadas na próxima vez que você a reativar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização CloudKit está desativada por predefinição. Quando ativada, o %@ sincroniza as publicações e os estilos através da sua base de dados privada do CloudKit; as alterações feitas enquanto estiver desativada (incluindo eliminações) são sincronizadas da próxima vez que a voltar a ativar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация через CloudKit отключена по умолчанию. Когда она включена, %@ синхронизирует заметки и стили через вашу частную базу данных CloudKit; изменения, внесённые при её отключении (включая удаления), синхронизируются при следующем включении."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit вимкнено за замовчуванням. Коли її ввімкнено, %@ синхронізує дописи та стилі через вашу приватну базу даних CloudKit; зміни, внесені поки вона вимкнена (зокрема видалення), синхронізуються наступного разу, коли її знову ввімкнено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步默认关闭。开启后，「%@」会通过你的私人 CloudKit 数据库同步便签和样式；关闭期间的改动（包括删除）会在下次开启时同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步預設關閉。開啓後，「%@」會透過你的私人 CloudKit 資料庫同步便籤和樣式；關閉期間的改動（包括刪除）會在下次開啓時同步。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步預設關閉。開啓後，「%@」會透過你的私人 CloudKit 資料庫同步便籤和樣式；關閉期間的改動（包括刪除）會在下次開啓時同步。"
          }
        }
      }
    },
    "settings.cloudKitSync.foregroundOnly.footer" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجلب %@ تغييرات iCloud عند فتحك للتطبيق. لم يتم تفعيل الدفع في الخلفية بعد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ruft iCloud-Änderungen ab, wenn du die App öffnest. Push im Hintergrund ist noch nicht aktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ pulls iCloud changes when you open the app. Background push is not yet enabled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ obtiene los cambios de iCloud cuando abres la app. La inserción en segundo plano aún no está activada."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ obtiene los cambios de iCloud cuando abres la app. El envío en segundo plano aún no está habilitado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ récupère les modifications iCloud à l’ouverture de l’app. La notification push en arrière-plan n’est pas encore activée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ recupera le modifiche di iCloud quando apri l'app. Il push in background non è ancora attivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ はアプリを開いたときに iCloud の変更を取得します。バックグラウンドプッシュはまだ有効になっていません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@은(는) 앱을 열 때 iCloud 변경 사항을 가져옵니다. 백그라운드 푸시는 아직 활성화되지 않았습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ obtém as alterações do iCloud quando você abre o app. O envio em segundo plano ainda não está ativado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O %@ obtém as alterações do iCloud quando abre a aplicação. O envio em segundo plano ainda não está ativado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ получает изменения iCloud при открытии приложения. Фоновая отправка пока не включена."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ отримує зміни iCloud, коли ви відкриваєте програму. Фонове надсилання ще не ввімкнено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」仅在你打开应用时从 iCloud 拉取最新内容，后台推送暂未启用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」僅在你打開應用時從 iCloud 拉取最新內容，背景推送暫未啓用。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」僅在你打開應用時從 iCloud 拉取最新內容，背景推送暫未啓用。"
          }
        }
      }
    },
