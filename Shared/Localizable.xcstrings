        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se gli errori di sincronizzazione continuano a ripresentarsi, ricostruisci la sincronizzazione CloudKit da questo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同期エラーが繰り返し発生する場合は、このデバイスから CloudKit 同期を再構築してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동기화 오류가 계속 발생하면 이 기기에서 CloudKit 동기화를 재구축하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
