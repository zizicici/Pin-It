    "settings.cloudKitSync.error.accountChanged" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تغيّر حساب iCloud. تم إيقاف مزامنة CloudKit؛ راجِع هذا الجهاز قبل إعادة تفعيلها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der iCloud-Account hat sich geändert. Die CloudKit-Synchronisierung wurde deaktiviert; überprüfe dieses Gerät, bevor du sie erneut aktivierst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The iCloud account changed. CloudKit Sync was turned off; review this device before turning it on again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cuenta de iCloud cambió. La sincronización con CloudKit se desactivó; revisa este dispositivo antes de volver a activarla."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cuenta de iCloud cambió. La sincronización con CloudKit se desactivó; revisa este dispositivo antes de volver a activarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le compte iCloud a changé. La synchronisation CloudKit a été désactivée ; vérifiez cet appareil avant de la réactiver."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'account iCloud è cambiato. La sincronizzazione CloudKit è stata disattivata; controlla questo dispositivo prima di riattivarla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud アカウントが変更されました。CloudKit 同期がオフになりました。再度オンにする前に、このデバイスを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 계정이 변경되었습니다. CloudKit 동기화가 꺼졌습니다. 다시 켜기 전에 이 기기를 확인하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conta do iCloud foi alterada. A Sincronização do CloudKit foi desativada; revise este dispositivo antes de ativá-la novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conta iCloud foi alterada. A sincronização CloudKit foi desativada; reveja este dispositivo antes de a voltar a ativar."
          }
        },
        "ru" : {
          "stringUnit" : {
