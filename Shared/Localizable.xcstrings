    "settings.cloudKitSync.disable.alert.message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستتوقف مزامنة CloudKit. ستبقى التغييرات التي تجريها أثناء إيقافها (بما في ذلك عمليات الحذف) على هذا الجهاز وستتم مزامنتها مع CloudKit عند إعادة تفعيلها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die CloudKit-Synchronisierung wird beendet. Änderungen, die du vornimmst, während sie deaktiviert ist (einschließlich Löschungen), bleiben auf diesem Gerät und werden mit CloudKit synchronisiert, sobald du sie wieder aktivierst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit Sync will stop. Changes you make while it is off (including deletions) stay on this device and will sync to CloudKit when you turn it back on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se detendrá. Los cambios que hagas mientras está desactivada (incluidas las eliminaciones) permanecerán en este dispositivo y se sincronizarán con CloudKit cuando la vuelvas a activar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronización con CloudKit se detendrá. Los cambios que hagas mientras está desactivada (incluidas las eliminaciones) permanecerán en este dispositivo y se sincronizarán con CloudKit cuando la vuelvas a activar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation CloudKit va s’arrêter. Les modifications que vous effectuez lorsqu’elle est désactivée (y compris les suppressions) restent sur cet appareil et seront synchronisées avec CloudKit lorsque vous la réactiverez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sincronizzazione CloudKit si interromperà. Le modifiche che apporti mentre è disattivata (incluse le eliminazioni) restano su questo dispositivo e verranno sincronizzate con CloudKit quando la riattivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同期を停止します。オフの間に行った変更（削除を含む）はこのデバイスに保持され、再度オンにしたときに CloudKit に同期されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 동기화가 중지됩니다. 꺼져 있는 동안 변경한 사항(삭제 포함)은 이 기기에 남아 있다가 다시 켜면 CloudKit에 동기화됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Sincronização do CloudKit será interrompida. As alterações feitas enquanto ela está desativada (incluindo exclusões) permanecem neste dispositivo e serão sincronizadas com o CloudKit quando você a reativar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sincronização CloudKit irá parar. As alterações que fizer enquanto estiver desativada (incluindo eliminações) permanecem neste dispositivo e serão sincronizadas com o CloudKit quando a voltar a ativar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронизация через CloudKit будет остановлена. Изменения, внесённые при её отключении (включая удаления), останутся на этом устройстве и будут синхронизированы с CloudKit, когда вы снова её включите."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Синхронізацію CloudKit буде зупинено. Зміни, внесені поки вона вимкнена (зокрема видалення), залишаються на цьому пристрої та синхронізуються з CloudKit, коли ви знову її ввімкнете."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步将停止。关闭期间的改动（包括删除）暂时只保存在这台设备，重新开启后会同步到 CloudKit。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步將停止。關閉期間的改動（包括刪除）暫時只保存在這台裝置，重新開啓後會同步到 CloudKit。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CloudKit 同步將停止。關閉期間的改動（包括刪除）暫時只保存在這部裝置，重新開啓後會同步到 CloudKit。"
          }
        }
      }
    },
